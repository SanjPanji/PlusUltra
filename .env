# Django
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostGIS)
POSTGRES_DB=plusultra
POSTGRES_USER=plusultra
POSTGRES_PASSWORD=plusultra
DATABASE_URL=postgis://plusultra:plusultra@db:5432/plusultra

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# JWT
ACCESS_TOKEN_LIFETIME_MINUTES=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# Route Optimization
FILL_LEVEL_THRESHOLD=70
CO2_EMISSION_FACTOR=0.27

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
